# ── RENTORA public (client) environment ──────────────────────────────────────
# Copy to `.env` and fill in from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# Only the PUBLIC anon key belongs here. It is safe to ship to the browser
# because Row Level Security enforces every access rule server-side.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key

# ── Server-only (NEVER prefix with VITE_, never commit real values) ───────────
# Used exclusively by the seed script (scripts/seed.mjs) and privileged tooling.
# The service-role key bypasses RLS — keep it out of all client code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
